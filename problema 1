import java.util.Scanner;
class MEDIA {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int cantidad;
        double suma = 0;
        
        System.out.println("Ingrese la cantidad de numeros que quiera en su vector: ");
        cantidad = scanner.nextInt();
        
        int[] a = new int[cantidad];
        
        for (int i = 0; i < cantidad; i++) {
            System.out.print("Ingrese el numero en la posición [" + i + "] : ");
            a[i] = scanner.nextInt();
            suma += (double) a[i] / cantidad;
        }
        System.out.println();
        
        System.out.println("Su vector es: ");
        for (int elementos : a) {
            System.out.print(elementos + " ");
        }
        System.out.println();
        
        System.out.println("\nLa media de los elementos de su vector es: ");
        System.out.print(suma);
    }
}
